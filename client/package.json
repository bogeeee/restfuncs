{
  "name": "restfuncs-client",
  "version": "3.0.0",
  "description": "Client for restfuncs-server. Allows you to seamlessly call server methods in RPC style.",
  "keywords": ["rpc","rest"],
  "author": "Boris Gingold <bogeee@bogitech.de>",
  "repository": {
    "type": "git",
    "url": "https://github.com/bogeeee/restfuncs.git",
    "directory": "client"
  },
  "license": "MIT",
  "type": "module",
  "main": "./dist/esm/index.js",
  "exports": {
    ".": {
      "browser": "./dist/esm/index.js",
      "import": "./dist/esm/index.js",
      "default": "./dist/esm/index.js",
      "types": "./dist/esm/index.d.ts"
    },
    "./__the_following_entries_are_for_development_for_jest_with_commonjs__": {},
    "./index": {
      "default": "./dist/commonjs/index.js"
    }
  },
  "scripts": {
    "dev:fastbuild": "tsc --build && tsc -module commonjs --outDir dist/commonjs",
    "clean": "tsc --build --clean && rimraf dist LICENSE readme.md",
    "build": "tsc --build --force && tsc -module ES6 --outDir dist/esm"
  },
  "dependencies": {
    "restfuncs-common": "^3.5.0",
    "underscore": "^1.13.3",
    "@brillout/json-serializer": "^0.5.25",
    "engine.io-client": "^6.6.3",
    "clone": "^2.1.2"
  },
  "devDependencies": {
    "@types/underscore": "^1.11.4",
    "@types/clone": "^2.1.4",
    "typescript": "5.x",
    "rimraf": "=5.0.5"
  }
}
